{
  "productName": "TaskForge",
  "version": "1.0.3",
  "identifier": "pl.taskforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "TaskForge",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Parametryzowane zadania edukacyjne",
    "longDescription": "TaskForge — zarządzaj parametryzowanymi zadaniami edukacyjnymi z klasyfikacją podstawy programowej, kluczem odpowiedzi, generowaniem testów i eksportem do Word.",
    "publisher": "jash90",
    "copyright": "MIT © 2026 jash90",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jash90/taskforge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1NDhEMUExRjFFODgyNkQKUldSdGd1anhvZEZJSlJKb3FrWHZpTTNmaFNJdkhUVXhHcEc3d2w0WFF0WXVCTElIT2xZNEpYKzcK"
    }
  }
}
